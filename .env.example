# ===================================================================
# Research Gatherer API — Environment Configuration
# Copy this file to .env and fill in your values.
# ===================================================================

# --- API Server ---
# Authentication (leave blank = open access for local dev)
RESEARCH_API_KEY=
# Server bind
RESEARCH_HOST=127.0.0.1
RESEARCH_PORT=8000
# Default output directory for research results
RESEARCH_OUTPUT_DIR=research_output

# --- LLM Provider ---
# Supported providers (set LLM_API_BASE to the /v1 endpoint):
#   OpenAI:        https://api.openai.com/v1
#   Ollama:        http://localhost:11434/v1
#   vLLM:          http://localhost:8001/v1
#   Groq:          https://api.groq.com/openai/v1
#   Together:      https://api.together.xyz/v1
#   Anyscale:      https://api.endpoints.anyscale.com/v1
#   LocalAI:       http://localhost:8080/v1
#   DeepSeek:      https://api.deepseek.com/v1
#   Moonshot:      https://api.moonshot.cn/v1
#   OpenRouter:    https://openrouter.ai/api/v1
#   Custom:        any OpenAI-compatible /v1 endpoint

LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=gpt-4o

# --- Research Behavior ---
# Max concurrent Jina parse workers
RESEARCH_PARSE_WORKERS=4
# Per-URL Jina timeout (seconds)
RESEARCH_JINA_TIMEOUT=30
# Rate limit delay between Jina calls (seconds, ignored when workers > 1)
RESEARCH_RATE_LIMIT=0.5
